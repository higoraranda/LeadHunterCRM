#!/bin/sh
# ----------------------------------------------------------------------------
# LeadHunter Maven Wrapper (self-contained, only-script style)
# Baixa Apache Maven automaticamente em .mvn/maven/ na primeira execucao.
# ----------------------------------------------------------------------------
set -e

BASE_DIR="$(cd "$(dirname "$0")" && pwd)"
MVN_VERSION="3.9.9"
MAVEN_HOME="$BASE_DIR/.mvn/maven"
DIST_URL="https://archive.apache.org/dist/maven/maven-3/$MVN_VERSION/binaries/apache-maven-$MVN_VERSION-bin.zip"
ZIP_PATH="$BASE_DIR/.mvn/maven.zip"

if [ ! -x "$MAVEN_HOME/bin/mvn" ]; then
  echo "[mvnw] Baixando Apache Maven $MVN_VERSION..."
  mkdir -p "$BASE_DIR/.mvn"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$DIST_URL" -o "$ZIP_PATH"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$DIST_URL" -O "$ZIP_PATH"
  else
    echo "[mvnw] ERRO: curl ou wget necessario para baixar Maven" >&2
    exit 1
  fi
  echo "[mvnw] Extraindo..."
  if command -v unzip >/dev/null 2>&1; then
    (cd "$BASE_DIR/.mvn" && unzip -q maven.zip)
  else
    # Fallback para ambientes onde unzip nao esta instalado (raro em Git Bash/WSL)
    (cd "$BASE_DIR/.mvn" && jar xf maven.zip)
  fi
  mv "$BASE_DIR/.mvn/apache-maven-$MVN_VERSION" "$MAVEN_HOME"
  rm -f "$ZIP_PATH"
  chmod +x "$MAVEN_HOME/bin/mvn"
  echo "[mvnw] Maven instalado em $MAVEN_HOME"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
